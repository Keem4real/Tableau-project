      <aliases enabled='yes' />
      <column caption='Total Shipmennt' datatype='integer' name='[Calculation_905505052378198016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Shipment_ID])' />
      </column>
      <column caption='Avg Supply time' datatype='real' name='[Calculation_905505052378972161]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Lead_Time_Days])' />
      </column>
      <column caption='Disruption rate' datatype='real' name='[Calculation_905505052379418626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Disruption_Occurred] = &quot;Yes&quot; THEN 1 ELSE 0 END) &#13;&#10;/ COUNT([Shipment_ID])' />
      </column>
      <column caption='On time Delivery (20days)' datatype='real' name='[Calculation_905505052381184003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Lead_Time_Days] &lt;= 20 THEN 1 ELSE 0 END)&#13;&#10;/ COUNT([Shipment_ID])' />
      </column>
      <column caption='Delay delivery(&gt;20days)' datatype='real' name='[Calculation_905505052997201925]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Lead_Time_Days] &gt; 20 THEN 1 ELSE 0 END)&#13;&#10;/ COUNT([Shipment_ID])' />
      </column>
